# =============================================================================
# RENDER / Production — set these in Render → Environment (not localhost)
# =============================================================================

# Required
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
OPENAI_API_KEY=your_openai_or_azure_key
FRONTEND_URL=https://your-app.vercel.app

# Optional (CORS — use FRONTEND_URL alone, or add more origins comma-separated)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app

# OpenAI.com (leave OPENAI_ENDPOINT empty)
OPENAI_MODEL=gpt-4o

# Azure OpenAI (set these instead of OPENAI_MODEL)
# OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# OPENAI_API_VERSION=2024-12-01-preview
# OPENAI_GPT_DEPLOYMENT=gpt-4o

MONGO_DB_NAME=document_extraction
MONGO_COLLECTION_NAME=extractions

# Render (512MB) — set on Render dashboard:
# OCR_LOW_MEMORY=true
# OCR_WARMUP_ON_STARTUP=false
# Build uses requirements-render.txt (PaddleOCR only, no PyTorch)

# =============================================================================
# Local development
# =============================================================================
# MONGO_URI=mongodb://localhost:27017
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=*
