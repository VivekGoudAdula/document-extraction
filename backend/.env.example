# OCR runs locally (PaddleOCR + TrOCR). Only semantic extraction uses OpenAI below.

# Azure OpenAI (recommended if you use Azure GPT-4o)
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_API_KEY=your_azure_openai_api_key
OPENAI_API_VERSION=2024-12-01-preview
OPENAI_GPT_DEPLOYMENT=gpt-4o

# Or OpenAI.com — leave OPENAI_ENDPOINT unset and set:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=document_extraction
MONGO_COLLECTION_NAME=extractions
CORS_ORIGINS=*
